---
import LayoutBase from "../../layouts/LayoutBase.astro";
import AuthorCard from "../../components/AuthorCard.astro";
import AuthorName from "../../components/AuthorName.astro";
import { getCollection } from "astro:content";
import { Image } from 'astro:assets';
const posts = await getCollection("news");
---

<LayoutBase
    MetaTitle="Nuestras Noticias - IA Unamba"
    title="Noticias"
    description="Compartimos nuestros avances, estudios y aportes científicos desde la universidad"
>
    <main class="max-w-7xl mx-auto p-4 sm:p-6">
        <section class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 md:gap-8">
            {
                posts.map((post) => {
                    const { slug, data } = post;
                    const {
                        title,
                        description,
                        date_publication,
                        cover_image,
                        tags,
                        author,
                        readingtime,
                        url_doi_org,
                    } = data;

                    return (
                        <a href={`/news/${slug}`}>
                            <article class="bg-[#181A1E] rounded-xl overflow-hidden hover:shadow-xl transition-shadow duration-300 text-white">
                                <Image
                                          src={cover_image}
                                          alt={title}
                                          width={800}
                                          height={400}
                                          class="w-full h-40 sm:h-48 object-cover rounded-lg mb-4"
                                />
                                <div class="py-3 sm:py-4 px-4 sm:px-6 flex flex-col gap-3 sm:gap-4">
                                    <div>
                                        <span class="text-[#B2BBC5] text-xs sm:text-sm uppercase block">
                                            {tags?.join(" | ")} | {readingtime}{" "}
                                            MIN READ
                                        </span>
                                        <h3 transition:name={`publication-${slug}`} class="font-bold text-base sm:text-lg line-clamp-4">{title}</h3>
                                    </div>
                                    <div class="flex -space-x-3">
                                        {author.map((id:any) => (
                                            <AuthorCard authorId={id} />
                                        ))}
                                    </div>
                                    <div class="flex flex-wrap gap-1 text-xs sm:text-sm">
                                        {author.map((id:any) => (
                                            <AuthorName authorId={id} /><span>,</span>
                                        ))}
                                        <span> {date_publication}</span>
                                    </div>
                                </div>
                            </article>
                        </a>
                    );
                })
            }
        </section>
    </main>
</LayoutBase>
