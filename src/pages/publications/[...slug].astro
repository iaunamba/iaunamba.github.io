---
import { getCollection, render } from "astro:content";
import { authors, type AuthorId } from "../../content/authors/authors";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
    const posts = await getCollection("publications");
    return posts.map((post) => ({
        params: { slug: post.slug },
        props: { post },
    }));
}

const { post } = Astro.props;
const { data, slug } = post;
const { title, url_doi_org, tags, author, date_publication, readingtime } =
    data;

const { Content } = await render(post);
---

<Layout title={title}>
    <main class="px-4 sm:px-8 md:px-16 lg:px-40 xl:px-60">
        <section
            class="text-center text-white py-8 sm:py-12 md:py-20 lg:py-30 mt-4 flex flex-col gap-4 sm:gap-6 md:gap-8"
        >
            <a
                href="/investigation"
                class="text-[#B2BBC5] hover:text-[#26BBFF] hover:cursor-pointer text-xs sm:text-sm flex items-center gap-2 justify-center"
                ><svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide lucide-arrow-left-icon lucide-arrow-left w-4 h-4 sm:w-5 sm:h-5"
                    ><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"
                    ></path></svg
                > Regresar</a
            >
            <span
                class="text-sm sm:text-base md:text-lg lg:text-xl text-[#B2BBC5] uppercase"
                >{tags?.join(" | ")} | {readingtime} min read</span
            >
            <h2
                class="font-bold text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl px-2"
                transition:name={`investigation-${slug}`}
            >
                {title}
            </h2>
            <span class="text-base sm:text-lg md:text-xl text-[#26BBFF] block"
                >{
                    author
                        .map((id) => authors[id as AuthorId]?.name || id)
                        .join(", ")
                }, <span class="text-[#B2BBC5]">{date_publication}</span></span
            >
            {
                url_doi_org ? (
                    <div class="flex justify-center mt-4 sm:mt-6">
                        <a
                            target="_blank"
                            rel="noopener noreferrer"
                            class="px-4 sm:px-6 py-2 sm:py-3 bg-white text-[#0F0F13] rounded-full hover:bg-gray-100 transition font-medium flex items-center gap-2 text-sm sm:text-base"
                            href={`${url_doi_org}`}
                        >
                            Leer el articulo{" "}
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="20"
                                height="20"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                class="lucide lucide-arrow-up-right-icon lucide-arrow-up-right w-4 h-4 sm:w-5 sm:h-5"
                            >
                                <>
                                    <path d="M7 7h10v10" />
                                    <path d="M7 17 17 7" />
                                </>
                            </svg>
                        </a>
                    </div>
                ) : (
                    ""
                )
            }
        </section>
        <article class="w-full">
            <div
                class="prose prose-sm sm:prose-base md:prose-lg prose-invert max-w-none justify-center"
            >
                <Content />
            </div>
        </article>
    </main>
</Layout>
