---
import Layout from "./Layout.astro";
const { MetaTitle, title, description } = Astro.props;
---

<Layout title={MetaTitle}>
    <section
        class="text-center text-white py-8 sm:py-12 md:py-20 lg:py-30 xl:py-40 px-4 sm:px-8 md:px-16 lg:px-40 xl:px-70 mt-20 sm:mt-24 md:mt-28"
    >
        <span
            class="text-base sm:text-lg md:text-xl lg:text-2xl xl:text-3xl text-[#B2BBC5] block mb-2 sm:mb-4"
            >{title}</span
        >
        <h2
            class="font-bold text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl"
        >
            {description}
        </h2>
    </section>
    <slot />
</Layout>
